# Camera
CAMERA_SOURCE=0
CAMERA_ID=CAM_001
CAMERA_LOCATION=Building A, Gate 2

# AI Model
MODEL_PATH=yolov8n.pt
CONFIDENCE_THRESHOLD=0.75
FRAME_CONFIRMATION_N=4
FRAME_CONFIRMATION_M=6
NMS_IOU_THRESHOLD=0.45
MIN_BBOX_AREA=400
IGNORE_ZONES=[]                 # JSON array of polygons, e.g. [[[0,0],[100,0],[100,100],[0,100]]]

# Video Buffer
BUFFER_SECONDS=60
CLIP_BEFORE_SECONDS=15
CLIP_AFTER_SECONDS=15
EVENTS_DIR=./events

# Avalanche
PRIVATE_KEY=0x...               # Wallet private key used for deploy + event logging
CONTRACT_ADDRESS=0x...          # Deployed EventLogger contract address
RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
CHAIN_ID=43113                  # 43113=Fuji, 43114=mainnet

# IPFS / Pinata
PINATA_API_KEY=your_key_here
PINATA_SECRET=your_secret_here

# Alerts
TELEGRAM_BOT_TOKEN=123456:ABC-DEF
TELEGRAM_CHAT_ID=-100123456789  # Group chat IDs are usually negative

# App
LOG_LEVEL=INFO
SQLITE_PATH=./sentinelchain.db
API_PORT=8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
RETRY_INTERVAL_SECONDS=60
RECONNECT_INTERVAL_SECONDS=30
PROCESS_FPS=10
